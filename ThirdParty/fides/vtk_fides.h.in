#ifndef vtk_fides_h
#define vtk_fides_h

/* Use the fides library configured for VTK.  */
#cmakedefine01 VTK_MODULE_USE_EXTERNAL_VTK_fides

#if VTK_MODULE_USE_EXTERNAL_VTK_fides
# define VTK_FIDES(x) <x>
#else
# define VTK_FIDES(x) <vtkfides/x>
#endif

#endif
